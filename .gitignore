# 忽略所有文件
*

# 包含 requirements.txt
!requirements.txt
!readme.md
!.env.example
!.gitignore
# 包含 GitHub Actions 工作流
!.github/
!.github/workflows/
!.github/workflows/*.yml
!.github/workflows/*.yaml
# 包含 app 目录
!app/
# 包含 app 目录下的所有文件
!app/**
!web/
!web/**
!mcpServer/
!mcpServer/**
!mcpClient/
!mcpClient/**
mcpClient/**/docs/

# 忽略所有 YAML 文件
*.yaml
*.yml
mcpClient/**/*.yaml
mcpClient/**/*.yml
app/**/*.yaml
app/**/*.yml
mcpServer/**/*.yaml
mcpServer/**/*.yml
web/**/*.yaml
web/**/*.yml
# 排除 app 目录下的 Python 缓存文件
app/**/__pycache__/
app/**/*.pyc
app/**/*.pyo
app/**/*.pyd
app/**/*.so
app/**/docs/
app/test/语法解释.md
app/agents/subgraphs/audit_contract_clause/config/rules.md
#排除mcpServer和mcpClient目录
# 排除 app 目录下的 Python 缓存文件
mcpServer/**/__pycache__/
mcpServer/**/*.pyc
mcpServer/**/*.pyo
mcpServer/**/*.pyd
mcpServer/**/*.so
mcpClient/**/__pycache__/
mcpClient/**/*.pyc
mcpClient/**/*.pyo
mcpClient/**/*.egg-info
mcpClient/**/*.pyd
mcpClient/**/*.so
mcpClient/**/*.yaml
.env
app/test/
app/data/
app/**/*.csv
app/**/*.pdf
app/**/*.docx
app/**/*.xlsx
web/Agent/node_modules/
web/Agent/dist/
web/Agent/public/app-config.json
