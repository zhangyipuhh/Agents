#==============================================
# 大模型配置 - 通用模型
#==============================================
# 模型类型：支持 openai, deepseek, ollama 等
model_type="openai"

# 模型名称：根据 model_type 选择对应的模型
# OpenAI: gpt-4, gpt-3.5-turbo
# DeepSeek: deepseek-chat, deepseek-coder
# Ollama: qwen3-vl:30b, llama3.2
model_name="your_model_name_here"

# API 密钥：用于访问远程模型服务
model_api_key="your_api_key_here"

# API 基础 URL：模型服务的地址
# OpenAI: https://api.openai.com/v1
# DeepSeek: https://api.deepseek.com
# Moonshot: https://api.moonshot.cn/v1
# Ollama: http://localhost:11434
model_api_base="your_api_base_url_here"

# 模型温度参数：控制生成多样性
# 取值范围：0.0 - 2.0
# 0.0: 最确定性，适合事实性任务
# 1.0: 平衡，适合一般对话
# 2.0: 最随机，适合创意任务
model_temperature=0.2

# 是否开启多模态：支持同时处理文本和图片
# true: 开启多模态（需要模型支持）
# false: 仅文本模式
is_multimodal="true"

# 是否启用并行工具调用
# none: 不传参（兼容所有模型，推荐）
# true: 启用并行工具调用
# false: 禁用并行工具调用
parallel_tool_calls=none

# Ollama 模型配置（仅对 Ollama 模型有效）
# 是否启用推理功能：true/false
ollama_reasoning=true
# 请求超时时间（秒）
ollama_timeout=120

#==============================================
# 大模型配置 - 视觉模型
#==============================================
# 视觉模型类型
model_type_vision="openai"

# 视觉模型名称（需要支持视觉输入的模型）
# OpenAI: gpt-4-vision-preview, gpt-4o
# Moonshot: moonshot-v1-8k-vision-preview, moonshot-v1-32k-vision-preview
model_name_vision="your_vision_model_name_here"

# 视觉模型 API 密钥
model_api_key_vision="your_vision_api_key_here"

# 视觉模型 API 基础 URL
model_api_base_vision="your_vision_api_base_url_here"

# 视觉模型温度参数
model_temperature_vision=0.2

#==============================================
# Word 输出配置
#==============================================
# 高亮颜色：十六进制格式
# FF0000: 红色
# 00FF00: 绿色
# 0000FF: 蓝色
# FFFF00: 黄色
highlight_color="FF0000"

# 输出目录：Word 文档输出路径
output_dir="app/agents/data/output"

#==============================================
# MapAgent MCP 工具标签过滤
#==============================================
# JSON 数组格式，如: '["map", "geo"]'
map_mcp_tags='["map", "geo"]'

#==============================================
# 配置示例
#==============================================
# 示例 1: DeepSeek 配置
# model_type="deepseek"
# model_name="deepseek-chat"
# model_api_key="sk-your-deepseek-api-key"
# model_api_base="https://api.deepseek.com"
# model_temperature=0.2
# is_multimodal="false"

# 示例 2: Ollama 本地模型配置
# model_type="ollama"
# model_name="qwen3-vl:30b"
# model_api_key="not_required"
# model_api_base="http://localhost:11434"
# model_temperature=0.2
# is_multimodal="true"

# 示例 3: Moonshot 视觉模型配置
# model_type_vision="openai"
# model_name_vision="moonshot-v1-8k-vision-preview"
# model_api_key_vision="sk-your-moonshot-api-key"
# model_api_base_vision="https://api.moonshot.cn/v1"
# model_temperature_vision=0.2

#==============================================
# 文件解析配置
#==============================================
# 是否启用远程文件解析服务（如 MinerU）
# true: 启用远程解析，使用 FileParserClient
# false: 使用本地 DocumentLoader 解析
file_parser_enabled="false"

# 远程解析服务地址
file_parser_server_url="http://mineru-openai-server:30000"

# 输出格式：json 或 md
# json: 解析结果存储为 .json 文件
# md: 解析结果存储为 .md 文件
file_parser_output_format="json"

# 远程解析允许的最大文件大小（MB），前端校验 + 后端校验共用，默认 3
file_parser_max_file_size="3"

# 解析服务 API 地址
file_parser_api_url="/api/v1/parse"

# 最大轮询重试次数
file_parser_max_retries=60

# 轮询间隔（秒）
file_parser_poll_interval=2.0

# 请求超时时间（秒）
file_parser_timeout=300

# 数据库配置
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/feature_agent
AUTH_STORAGE_MODE=postgres
#web api 目标地址
VITE_API_TARGET=http://localhost:8003
#----------------------------------------------
# 演示测试配置
#----------------------------------------------
# ---演示报告生成配置,为true时开启演示报告生成
#----------------------------------------------
demonstration_report_enabled="true"
#==============================================
# Sandbox 沙箱配置
#==============================================
# Docker 部署模式：local / socket / dind / k8s
# local:  本地直接跑（应用进程 = 宿主机），路径无需投影
# socket: 应用容器挂载宿主机 /var/run/docker.sock，路径需通过 host_workspace_prefix 投影
# dind:   Docker-in-Docker（应用容器内嵌 daemon）
# k8s:    通过 K8s API 创建 Pod（占位，未实现）
sandbox_docker_mode="local"

# Docker daemon URL，socket 模式必填，例如 unix:///var/run/docker.sock
sandbox_docker_host=""

# 沙箱镜像名
sandbox_image="python:3.12-alpine"

# 容器内存限制（MB），默认 512
sandbox_max_memory_mb=512

# 容器 CPU 限制（百分比），默认 100
sandbox_max_cpu_percent=100

# 是否启用容器网络，默认 false
sandbox_network_enabled="false"

# 命令默认超时（秒），默认 60
sandbox_default_timeout=60

# 容器内工作目录（bind mount target），默认 /workspace
sandbox_container_workspace="/workspace"

# 宿主机视角工作目录前缀，socket 模式必填
sandbox_host_workspace_prefix=""

# Docker 不可用时是否降级到本地文件系统执行
# true:  使用 LocalShellBackend 在本地 workspace 继续运行（失去 Docker 隔离，仅限开发/可信环境）
# false: 仅返回清晰错误，保持安全边界（默认）
sandbox_fallback_to_local="false"

#==============================================
# 飞书 Open API 配置
#==============================================
# 飞书应用 App ID（在飞书开放平台 > 应用详情获取）
feishu_app_id=""
# 飞书应用 App Secret
feishu_app_secret=""
# 默认接收方 ID（如群 chat_id: oc_xxx；用户 open_id: ou_xxx）
feishu_default_receive_id=""
# 默认接收方类型：chat_id / open_id / user_id / email
feishu_default_receive_id_type="chat_id"
# SDK 日志级别：DEBUG / INFO / WARNING / ERROR
feishu_log_level="INFO"

#==============================================
# DevOps SSH 服务器配置（2026-07-15 新增）
#==============================================
# Fernet 对称密钥，用于加解密 devops_servers.password_encrypted 字段。
# 必须由 Fernet.generate_key() 生成（44 字节 url-safe base64）。
# 生成命令：python -c "from cryptography.fernet import Fernet; print(Fernet.generate_key().decode())"
# 留空时 lifespan 会跳过 DevOpsServerService 挂载，admin API 返回 500 + hint。
DEVOPS_CREDENTIAL_KEY=""
# 可选：servers.yaml 路径（默认 <项目根>/data/devops/servers.yaml）
# DEVOPS_SERVERS_CONFIG_PATH=data/devops/servers.yaml