# SSH 服务器配置文件
# 配置远程服务器的连接信息

servers:
  - name: "示例服务器-开发环境"
    host: "YOUR_IP_HERE"
    port: 22
    username: "YOUR_USERNAME_HERE"
    password: "YOUR_PASSWORD_HERE"  # 或使用 private_key_path
    # private_key_path: "/path/to/private/key"
    server_type: "linux"  # linux 或 windows
    timeout: 30

  - name: "示例服务器-生产环境"
    host: "YOUR_PROD_IP_HERE"
    port: 22
    username: "YOUR_USERNAME_HERE"
    private_key_path: "/path/to/private/key"
    server_type: "linux"
    timeout: 30
