# 命令黑名单配置文件
# 定义禁止执行的高危命令

blacklist:
  # 破坏性命令 - 精确匹配
  - "rm -rf /"
  - "rm -rf /*"
  - "rm -rf /tmp"
  - "rm -rf /var"
  - "rm -rf /home"
  - "rm -rf /root"
  - "rm -rf /usr"
  - "rm -rf /bin"
  - "rm -rf /sbin"
  - "rm -rf /lib"
  - "rm -rf /lib64"
  - "rm -rf /etc"
  - "rm -rf /boot"

  # 系统关机/重启命令
  - "shutdown"
  - "shutdown now"
  - "reboot"
  - "halt"
  - "poweroff"
  - "init 0"
  - "init 6"
  - "systemctl poweroff"
  - "systemctl reboot"
  - "systemctl halt"

  # 磁盘格式化命令
  - "mkfs.ext4"
  - "mkfs.xfs"
  - "mkfs.ntfs"
  - "mkfs.vfat"
  - "fdisk"
  - "parted"

  # 危险的数据库操作 - 正则匹配
  - "^(?i).*drop\\s+database"
  - "^(?i).*drop\\s+table"
  - "^(?i).*delete\\s+from\\s+.*where\\s+1\\s*=\\s*1"
  - "^(?i).*truncate\\s+table"

  # 危险的权限修改
  - "chmod -R 777 /"
  - "chmod -R 777 /*"
  - "chown -R root:root /"

  # 网络危险操作
  - "iptables -F"
  - "iptables -X"
  - "ufw disable"

  # 前缀匹配模式（以空格结尾表示前缀匹配）
  - "rm -rf "  # 匹配任何以 rm -rf 开头的命令
  - "dd if="   # 匹配 dd 命令
