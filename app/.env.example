# ==================================================================
# 大模型参数，通用
# ==================================================================
model_name="MiniMax-M2.7"
model_type="anthropic"
model_api_key="sk-cp-6HIrsFMPcx3smQXMRR7d2m22dogDhHXwptpkeTPPtaYbYDj8SE1xbiihAKPm1MKahM7bxR8Oagr54E7H6v67n9_F3iUoq0lzWDFOM7sV2Gh4AEJWLKlhx0s"
model_api_base="https://api.minimaxi.com/anthropic"
model_temperature=0.2
is_multimodal="false"
# 是否启用并行工具调用：none表示不传参（兼容所有模型），true/false显式设置
parallel_tool_calls=none
# Ollama 模型推理功能开关：true/false
ollama_reasoning=true
# Ollama 模型请求超时时间（秒）
ollama_timeout=120

# ==================================================================
# 大模型参数，视觉模型
# ==================================================================
model_type_vision="anthropic"
model_name_vision="moonshot-v1-8k-vision-preview"
model_api_key_vision="sk-cp-6HIrsFMPcx3smQXMRR7d2m22dogDhHXwptpkeTPPtaYbYDj8SE1xbiihAKPm1MKahM7bxR8Oagr54E7H6v67n9_F3iUoq0lzWDFOM7sV2Gh4AEJWLKlhx0s"
model_api_base_vision="https://api.moonshot.cn/v1"
model_temperature_vision=0.2

# ==================================================================
# MCP Sampling 大模型参数（供 MCP Server 回调 LLM 使用）
# ==================================================================
mcp_sampling_model_type="anthropic"
mcp_sampling_model_name="MiniMax-M2.7"
mcp_sampling_model_api_key="sk-cp-6HIrsFMPcx3smQXMRR7d2m22dogDhHXwptpkeTPPtaYbYDj8SE1xbiihAKPm1MKahM7bxR8Oagr54E7H6v67n9_F3iUoq0lzWDFOM7sV2Gh4AEJWLKlhx0s"
mcp_sampling_model_api_base="https://api.minimaxi.com/anthropic"
mcp_sampling_model_temperature=0.0
mcp_sampling_is_multimodal="false"

# ==================================================================
# MapAgent MCP 工具标签过滤
# ==================================================================
map_mcp_tags='["map", "geo", "test"]'

# ==================================================================
# 文件解析配置
# ==================================================================
# 是否启用远程文件解析服务（如 MinerU）
# true: 启用远程解析，使用 FileParserClient
# false: 使用本地 DocumentLoader 解析
file_parser_enabled="true"
# 远程解析服务地址
file_parser_server_url="http://mineru-openai-server:30000"
# 输出格式：json 或 md
file_parser_output_format="md"
# 解析服务 API 地址
file_parser_api_url="http://localhost:8000/file_parse"
# 最大轮询重试次数
file_parser_max_retries=60
# 轮询间隔（秒）
file_parser_poll_interval=2.0
# 请求超时时间（秒）
file_parser_timeout=300

# ==================================================================
# 数据库配置
# ==================================================================
DATABASE_URL=postgresql://postgres:postgres@localhost:5432/feature_agent
AUTH_STORAGE_MODE=memory

# ==================================================================
# Web API 目标地址
# ==================================================================
VITE_API_TARGET=http://localhost:8003


